{
  "production_mode": true,
  "port": 8080,
  "http": {
    "enable_keep_alive": true,
    "thread_pool_size": 4
  },
  "smb": {
    "enabled": false,
    "port": 445,
    "require_signing": false,
    "enable_encryption": false,
    "server_name": "YUAN-NAS",
    "domain_name": "WORKGROUP"
  },
  "nas": {
    "webdav_mount": "/dav",
    "admin_console_path": "./server/services/resources/nas_admin_console.html",
    "allow_anonymous_read": false,
    "redis": {
      "enabled": true,
      "host": "127.0.0.1",
      "port": 6379,
      "db": 0,
      "key_prefix": "yuan:nas:",
      "audit_max_events": 1000
    },
    "audit": {
      "file_enabled": true,
      "file_path": "./logs/nas-audit.jsonl",
      "max_events": 1000
    },
    "users": [
      {
        "id": "admin-1",
        "username": "admin",
        "password_hash": "pbkdf2-sha256$210000$nas$696f91def74b1382921221cfb768a3b9dcc58c885f551c84d0816b6eb017ecb6",
        "enabled": true,
        "admin": true
      }
    ],
    "shares": [
      {
        "id": "share-public",
        "name": "public",
        "root_path": "/srv/yuan/nas/public",
        "windows_root_path": "D:/misc",
        "root_env": "YUAN_NAS_SHARE_ROOT",
        "enabled": true,
        "readonly": false,
        "default_permissions": ["read", "write", "remove"]
      }
    ]
  }
}
