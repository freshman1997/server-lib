{
  "server": {
    "listen": 8080,
    "server_name": "mini-nginx",
    "thread_pool_size": 2,
    "worker_processes": 1,
    "enable_ssl": false,
    "enable_keep_alive": true,
    "enable_cors": true,
    "enable_http2": true,
    "use_iocp": true,
    "iocp_worker_count": 4,
    "backlog": 1024,
    "allowed_methods": ["GET", "HEAD", "POST", "PUT", "DELETE", "OPTIONS", "PATCH"],
    "max_connections": 0,
    "max_connections_per_ip": 0,
    "max_inflight_requests_per_ip": 0,
    "max_concurrent_requests_per_ip": 0,
    "max_body_size": 10485760
  },
  "access_log": {
    "enabled": true,
    "json": true,
    "path": "release/mini_nginx/access.log"
  },
  "reload_check_interval_ms": 1000,
  "rate_limit": {
    "enabled": false,
    "requests_per_second": 100,
    "burst": 50
  },
  "health": {
    "enabled": true,
    "path": "/healthz",
    "json": true
  },
  "headers": {
    "add": {
      "X-Content-Type-Options": "nosniff",
      "X-Frame-Options": "SAMEORIGIN",
      "Referrer-Policy": "strict-origin-when-cross-origin"
    }
  },
  "redirects": [
    {
      "from": "/old-static",
      "to": "/static",
      "code": 301,
      "prefix": true,
      "preserve_path": true
    }
  ],
  "static": [
    {
      "location": "/static",
      "root": "release/mini_nginx/www",
      "auto_index": true,
      "enable_range": true,
      "index": ["index.html", "index.htm"],
      "try_files": ["$uri", "$uri/index.html", "/index.html", "=404"],
      "error_page": {
        "404": "/404.html"
      }
    }
  ],
  "upstreams": {
    "api_backend": {
      "balance": "round_robin",
      "connect_timeout": 3000,
      "read_timeout": 30000,
      "write_timeout": 10000,
      "max_retries": 1,
      "pool_size": 16,
      "idle_timeout": 60,
      "servers": [
        { "host": "127.0.0.1", "port": 9001, "weight": 1 },
        { "host": "127.0.0.1", "port": 9002, "weight": 1 }
      ]
    },
    "ws_backend": {
      "balance": "round_robin",
      "connect_timeout": 3000,
      "read_timeout": 60000,
      "write_timeout": 60000,
      "max_retries": 0,
      "pool_size": 4,
      "idle_timeout": 30,
      "servers": [
        { "host": "127.0.0.1", "port": 9010, "weight": 1 }
      ]
    }
  },
  "routes": [
    {
      "path": "/api/",
      "proxy_pass": "api_backend",
      "strip_prefix": false
    },
    {
      "path": "/ws/",
      "proxy_pass": "ws_backend",
      "strip_prefix": false
    }
  ]
}
